{
  "version": 1,
  "project": {
    "name": "goodbot-ai",
    "framework": "node",
    "language": "typescript"
  },
  "architecture": {
    "layers": [
      {
        "name": "config",
        "path": "src/config",
        "level": 1,
        "hasBarrel": true,
        "role": {
          "id": "config",
          "displayName": "Config/Bootstrap",
          "description": "Env, secrets, feature flags, bootstrap wiring"
        }
      },
      {
        "name": "utils",
        "path": "src/utils",
        "level": 1,
        "hasBarrel": true,
        "role": {
          "id": "utils",
          "displayName": "Utilities",
          "description": "Pure helpers with no framework or domain coupling"
        }
      },
      {
        "name": "analyzers",
        "path": "src/analyzers",
        "level": 4,
        "hasBarrel": true,
        "role": {
          "id": "feature",
          "displayName": "Feature",
          "description": "Domain-specific feature module"
        }
      },
      {
        "name": "commands",
        "path": "src/commands",
        "level": 4,
        "hasBarrel": false,
        "role": {
          "id": "feature",
          "displayName": "Feature",
          "description": "Domain-specific feature module"
        }
      },
      {
        "name": "freshness",
        "path": "src/freshness",
        "level": 4,
        "hasBarrel": true,
        "role": {
          "id": "feature",
          "displayName": "Feature",
          "description": "Domain-specific feature module"
        }
      },
      {
        "name": "generators",
        "path": "src/generators",
        "level": 4,
        "hasBarrel": true,
        "role": {
          "id": "feature",
          "displayName": "Feature",
          "description": "Domain-specific feature module"
        }
      },
      {
        "name": "scanners",
        "path": "src/scanners",
        "level": 4,
        "hasBarrel": true,
        "role": {
          "id": "feature",
          "displayName": "Feature",
          "description": "Domain-specific feature module"
        }
      },
      {
        "name": "templates",
        "path": "src/templates",
        "level": 4,
        "hasBarrel": false,
        "role": {
          "id": "feature",
          "displayName": "Feature",
          "description": "Domain-specific feature module"
        }
      }
    ],
    "dependencyDirection": "downward",
    "barrelImportRule": "always",
    "interfaceContracts": false,
    "systemType": "api"
  },
  "businessLogic": {
    "allowedIn": [
      "services"
    ],
    "forbiddenIn": [
      "routes",
      "controllers"
    ],
    "redFlags": [
      "Business logic in route handlers",
      "Direct database calls in controllers",
      "Missing error handling in async operations"
    ]
  },
  "verification": {
    "typecheck": "npm run typecheck",
    "lint": "npm run lint",
    "test": "npm test",
    "format": null,
    "build": "npm run build"
  },
  "agentFiles": {
    "claudeMd": true,
    "cursorrules": true,
    "windsurfrules": true,
    "agentsMd": true,
    "cursorignore": true,
    "codingGuidelines": true,
    "existingFileStrategy": "merge"
  },
  "conventions": {
    "mainBranch": "main",
    "importStyle": "barrel",
    "customRules": []
  },
  "analysis": {
    "solid": true,
    "thresholds": {
      "maxFileLines": 300,
      "maxBarrelExports": 15,
      "maxModuleCoupling": 8
    },
    "budget": {}
  },
  "customRulesConfig": [],
  "team": {},
  "ignore": {
    "paths": [
      "node_modules",
      "dist",
      "build",
      "coverage",
      "*.lock",
      ".env",
      ".env.*"
    ],
    "sensitiveFiles": [
      ".env",
      ".env.*",
      "credentials.json",
      "*.pem",
      "*.key"
    ]
  }
}
