{
  "name": "goodbot-ai",
  "version": "0.7.0",
  "description": "Auto-generate AI agent guardrail files for your project. Train your AI to be a good bot.",
  "type": "module",
  "bin": {
    "goodbot": "./bin/goodbot.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "bin/"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "npm run clean && tsc -p tsconfig.build.json && npm run copy-templates",
    "clean": "rm -rf dist",
    "copy-templates": "cp -r src/templates dist/templates",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai",
    "agent",
    "guardrails",
    "claude",
    "cursor",
    "windsurf",
    "codex",
    "copilot",
    "cli",
    "coding-standards",
    "vibe-coding"
  ],
  "author": "timeritual",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/timeritual/goodbot-ai.git"
  },
  "homepage": "https://github.com/timeritual/goodbot-ai#readme",
  "bugs": {
    "url": "https://github.com/timeritual/goodbot-ai/issues"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^4.0.3",
    "commander": "^12.1.0",
    "handlebars": "^4.7.8",
    "inquirer": "^9.3.0",
    "ora": "^8.0.1",
    "picomatch": "^4.0.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.0.0",
    "@types/picomatch": "^4.0.3",
    "eslint": "^10.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^2.0.0"
  }
}
